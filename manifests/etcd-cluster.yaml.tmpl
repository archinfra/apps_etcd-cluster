apiVersion: v1
kind: Namespace
metadata:
  name: __NAMESPACE__
  labels:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
---
apiVersion: v1
kind: Service
metadata:
  name: etcd-headless
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
    app.kubernetes.io/component: database
spec:
  clusterIP: None
  publishNotReadyAddresses: true
  selector:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
  ports:
  - name: client
    port: 2379
    targetPort: client
  - name: peer
    port: 2380
    targetPort: peer
---
apiVersion: v1
kind: Service
metadata:
  name: etcd-client
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
    app.kubernetes.io/component: database
spec:
  type: __SERVICE_TYPE__
  selector:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
  ports:
  - name: client
    port: 2379
    targetPort: client
    protocol: TCP
__NODEPORT_CLIENT_LINE__
---
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: etcd
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
    app.kubernetes.io/component: database
spec:
  maxUnavailable: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: etcd
      app.kubernetes.io/instance: etcd
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: etcd
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: etcd
    app.kubernetes.io/instance: etcd
    app.kubernetes.io/component: database
spec:
  serviceName: etcd-headless
  replicas: __REPLICAS__
  podManagementPolicy: Parallel
  updateStrategy:
    type: RollingUpdate
  selector:
    matchLabels:
      app.kubernetes.io/name: etcd
      app.kubernetes.io/instance: etcd
  template:
    metadata:
      labels:
        app.kubernetes.io/name: etcd
        app.kubernetes.io/instance: etcd
        app.kubernetes.io/component: database
    spec:
      terminationGracePeriodSeconds: 30
      affinity:
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - weight: 100
            podAffinityTerm:
              labelSelector:
                matchLabels:
                  app.kubernetes.io/name: etcd
                  app.kubernetes.io/instance: etcd
              topologyKey: kubernetes.io/hostname
      containers:
      - name: etcd
        image: __ETCD_IMAGE__
        imagePullPolicy: IfNotPresent
        command:
        - /usr/local/bin/etcd
        args:
        - --name=$(POD_NAME)
        - --data-dir=/etcd-data
        - --listen-client-urls=http://0.0.0.0:2379
        - --advertise-client-urls=http://$(POD_NAME).etcd-headless.__NAMESPACE__.svc.cluster.local:2379
        - --listen-peer-urls=http://0.0.0.0:2380
        - --initial-advertise-peer-urls=http://$(POD_NAME).etcd-headless.__NAMESPACE__.svc.cluster.local:2380
        - --initial-cluster=__INITIAL_CLUSTER__
        - --initial-cluster-state=new
        - --initial-cluster-token=__CLUSTER_TOKEN__
        - --logger=zap
        - --log-level=info
        - --log-outputs=stderr
        - --auto-compaction-mode=periodic
        - --auto-compaction-retention=1h
        ports:
        - name: client
          containerPort: 2379
          protocol: TCP
        - name: peer
          containerPort: 2380
          protocol: TCP
        env:
        - name: ETCDCTL_API
          value: "3"
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        readinessProbe:
          exec:
            command:
            - /usr/local/bin/etcdctl
            - --endpoints=http://127.0.0.1:2379
            - endpoint
            - health
          initialDelaySeconds: 10
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 12
        livenessProbe:
          exec:
            command:
            - /usr/local/bin/etcdctl
            - --endpoints=http://127.0.0.1:2379
            - endpoint
            - health
          initialDelaySeconds: 30
          periodSeconds: 20
          timeoutSeconds: 5
          failureThreshold: 6
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            memory: 1Gi
        volumeMounts:
        - name: data
          mountPath: /etcd-data
  volumeClaimTemplates:
  - metadata:
      name: data
      labels:
        app.kubernetes.io/name: etcd
        app.kubernetes.io/instance: etcd
        app.kubernetes.io/component: database
    spec:
      accessModes:
      - ReadWriteOnce
__STORAGE_CLASS_LINE__
      resources:
        requests:
          storage: __STORAGE_SIZE__
